generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Job {
  id             String      @id @default(cuid())
  officeName     String      // 事業所名
  jobTitle       String      // 職種
  employmentType String      // 正社員 | パート
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  records        JobRecord[]
}

model JobRecord {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type          String   // "team-a" | "team-b"
  platform      String   // "indeed" | "airwork" | "jobmedley"
  inputData     String?  // JSON
  outputData    String?  // JSON
  metricsData   String?  // JSON
  thumbnailUrls String?  // JSON: string[]
  createdAt     DateTime @default(now())
}
